{
	"version": "2.0.0",
	"inputs": [
		{
			"id": "nukeNdkRoot",
			"type": "promptString",
			"description": "NUKE_NDK_ROOT path",
			"default": "${workspaceFolder}/nuke_ndk"
		},
		{
			"id": "nukeVersion",
			"type": "promptString",
			"description": "NUKE_VERSION folder name",
			"default": "16.1v2"
		}
	],
	"tasks": [
		{
			"label": "Build Nuke Plugin",
			"type": "shell",
			"command": "bash",
			"args": [
				"scripts/build.sh"
			],
			"windows": {
				"command": "powershell",
				"args": [
					"-ExecutionPolicy",
					"Bypass",
					"-File",
					"scripts/build.ps1"
				]
			},
			"linux": {
				"command": "bash",
				"args": [
					"scripts/build.sh"
				]
			},
			"options": {
				"env": {
					"NUKE_NDK_ROOT": "${input:nukeNdkRoot}",
					"NUKE_VERSION": "${input:nukeVersion}"
				}
			},
			"isBackground": false,
			"problemMatcher": [],
			"group": {
				"kind": "build"
			}
		},
		{
			"label": "Build Nuke Plugin (Debug Symbols)",
			"type": "shell",
			"linux": {
				"command": "bash",
				"args": [
					"-lc",
					"cmake -S . -B build-debug -DNUKE_NDK_ROOT=\"$NUKE_NDK_ROOT\" -DNUKE_VERSION=\"$NUKE_VERSION\" -DCMAKE_BUILD_TYPE=Debug && cmake --build build-debug --target package_plugin"
				]
			},
			"options": {
				"env": {
					"NUKE_NDK_ROOT": "${input:nukeNdkRoot}",
					"NUKE_VERSION": "${input:nukeVersion}"
				}
			},
			"isBackground": false,
			"problemMatcher": [],
			"group": {
				"kind": "build"
			}
		}
	]
}